NEXT_PUBLIC_SITE_URL=https://your-domain.com

# URL of the admin dashboard API (server-side only)
API_URL=http://localhost:3001

# URL of the admin dashboard API (client-side, for contact form and other client fetches)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Shared secret for on-demand revalidation (must match REVALIDATION_SECRET in admin dashboard)
REVALIDATION_SECRET=your-revalidation-secret-here
